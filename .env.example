# Radio Bloom - Environment Configuration
# Copy this file to .env and fill in your values

# API
API_PORT=9876

# Liquidsoap
LIQUIDSOAP_HOST=liquidsoap
LIQUIDSOAP_TELNET_PORT=1234
LIQUIDSOAP_HARBOUR_PORT=8000

# Publisher
PUBLISHER_PORT=3000

# Spotify (Client Credentials - https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# FTP
FTP_PUBLIC_HOST=localhost
FTP_PORT=21
FTP_PASSIVE_MIN=30000
FTP_PASSIVE_MAX=30009
FTP_USER_NAME=radio
FTP_USER_PASS=changeme
FTP_USER_HOME=/home/radio
FTP_UMASK=133
