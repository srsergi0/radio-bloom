# Radio Bloom - Environment Configuration
# Copy this file to .env and fill in your values

# API
API_PORT=9876

# Liquidsoap
LIQUIDSOAP_HOST=liquidsoap
LIQUIDSOAP_TELNET_PORT=1234
LIQUIDSOAP_HARBOUR_PORT=8000

# Publisher
PUBLISHER_PORT=3000
PUBLISHER_URL=http://publisher:3000

# Metadata Enricher
ENRICHER_URL=http://metadata-enricher:4001

# Watchdog
HEALTH_CHECK_INTERVAL=30000

# FTP
FTP_PUBLIC_HOST=185.139.1.222
FTP_PORT=21
FTP_PASSIVE_MIN=30000
FTP_PASSIVE_MAX=30009
FTP_USER_NAME=radio
FTP_USER_PASS=radiobloom
FTP_USER_HOME=/home/radio
FTP_UMASK=133
