---
import Button from './ui/Button.astro';

interface Props {
  isEn?: boolean;
}

const { isEn = false } = Astro.props;
---

<section class="events-section" id="events-section">
  <div class="section-container">
    <div class="event-brutalist-split">
      
      <!-- Left Side: Solid Orange text info block -->
      <div class="event-text-block">
        <span class="mono-tag text-dark">[ {isEn ? "EXPERIENCES" : "EXPERIENCIAS"} ]</span>
        <h2 class="event-title">
          {isEn ? "Live the music, live Bloom." : "Vive la música, vive Bloom."}
        </h2>
        <p class="event-description">
          {isEn 
            ? "Concerts, festivals, and independent musical experiences. Discover our upcoming scheduled sound sessions." 
            : "Conciertos, festivales y experiencias sonoras independientes. Descubre nuestras próximas sesiones de sonido programadas."}
        </p>
        <Button href="#events-section" variant="outline" size="md" class="event-btn">
          {isEn ? "VIEW ALL EVENTS ↗" : "VER EVENTOS ↗"}
        </Button>
      </div>
      
      <!-- Right Side: Grayscale high-contrast concert image -->
      <div class="event-image-block">
        <div class="image-wrapper" style="background-image: url('/images/concert_crowd_banner.png');">
          <div class="image-overlay"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .events-section {
    padding: 6rem 3rem;
    max-width: 100%;
    background-color: #000000;
    border-bottom: 2px solid #ffffff;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Split layout with thick black borders */
  .event-brutalist-split {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    border: 2px solid #ffffff; /* White block outline */
    box-shadow: 6px 6px 0px #ffffff;
    overflow: hidden;
  }

  /* Text column: Orange background with black text */
  .event-text-block {
    background-color: var(--color-orange);
    color: var(--color-text-dark);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 1.5rem;
    border-right: 2px solid #ffffff;
  }

  .text-dark {
    color: var(--color-text-dark);
    font-weight: 700;
  }

  .event-title {
    font-size: 2.75rem;
    font-weight: 900;
    color: var(--color-text-dark);
    line-height: 1.1;
    letter-spacing: -0.04em;
    font-family: var(--font-sans);
  }

  .event-description {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--color-text-dark);
    opacity: 0.9;
    font-family: var(--font-sans);
  }

  /* Button style override for black outline on orange */
  .event-btn {
    border-color: #000000 !important;
    color: #000000 !important;
  }

  /* Image column: high-contrast dark grayscale image */
  .event-image-block {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 350px;
  }

  .image-wrapper {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: grayscale(1) contrast(1.3) brightness(0.85); /* Raw, high contrast grayscale */
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(139, 92, 246, 0.05); /* Very subtle tint */
    mix-blend-mode: color;
  }

  @media (max-width: 992px) {
    .event-brutalist-split {
      grid-template-columns: 1fr;
    }
    .event-text-block {
      border-right: none;
      border-bottom: 2px solid #ffffff;
      padding: 2rem;
    }
    .event-image-block {
      min-height: 250px;
    }
    .events-section {
      padding: 4rem 1.5rem;
    }
    .event-title {
      font-size: 2rem;
    }
  }
</style>
