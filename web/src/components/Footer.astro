---
interface Props {
  isEn?: boolean;
}

const { isEn = true } = Astro.props;
---

<footer class="bg-black text-white border-t-2 border-white px-4 sm:px-6 md:px-12 py-12 md:py-24 overflow-hidden" id="footer">
  <div class="max-w-[1200px] mx-auto">
    
    <!-- Newsletter Form matching the inputs of Mockup 3 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 pb-10 md:pb-16 border-b-2 border-white">
      <div>
        <span class="font-mono text-xs sm:text-sm font-bold text-orange block mb-2">[ {isEn ? "NEWSLETTER" : "BOLETÍN"} ]</span>
        <h3 class="text-2xl sm:text-4xl font-black uppercase tracking-tight leading-tight">{isEn ? "Join the movement" : "Únete al movimiento"}</h3>
      </div>
      
      <form class="flex flex-col sm:flex-row lg:flex-col items-stretch gap-6 lg:justify-end" onsubmit="event.preventDefault()">
        <div class="flex flex-col relative flex-grow">
          <label class="font-mono text-[10px] font-bold text-neutral-400 mb-1" for="news-email">{isEn ? "YOUR EMAIL..." : "TU CORREO ELECTRÓNICO..."}</label>
          <input type="email" id="news-email" class="newsletter-input bg-transparent border-none border-b-2 border-white text-white py-2 text-base font-sans outline-none transition-colors focus:border-orange" required />
        </div>
        <button type="submit" class="self-start font-mono text-xs sm:text-sm font-bold bg-white text-black border-2 border-white px-6 py-3 cursor-pointer transition-all shadow-[4px_4px_0px_#ff3b00] hover:shadow-[6px_6px_0px_#ff3b00] hover:-translate-x-0.5 hover:-translate-y-0.5 active:translate-x-0.5 active:translate-y-0.5 active:shadow-[2px_2px_0px_#ff3b00]">
          {isEn ? "PRE-REGISTER ↗" : "SUSCRIBIRSE ↗"}
        </button>
      </form>
    </div>

    <!-- Navigation grid split with white borders -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 py-10 md:py-16 border-b-2 border-white">
      <!-- brand / socials -->
      <div class="col-span-1 sm:col-span-2 md:col-span-1 flex flex-col gap-4">
        <div class="font-sans text-xl font-black text-white lowercase">bloom radio®</div>
        <div class="flex flex-col gap-2 font-mono text-xs font-bold text-neutral-400">
          <a href="#" class="hover:text-white transition-colors">INSTAGRAM</a>
          <a href="#" class="hover:text-white transition-colors">TWITTER</a>
          <a href="#" class="hover:text-white transition-colors">YOUTUBE</a>
        </div>
      </div>

      <!-- Links Col 1 -->
      <div class="flex flex-col gap-4">
        <h5 class="font-mono text-xs font-bold text-orange uppercase">{isEn ? "EXPLORE" : "EXPLORAR"}</h5>
        <ul class="list-none flex flex-col gap-2.5">
          <li><a href="#programs-section" class="font-sans text-sm text-neutral-400 font-medium hover:text-white transition-colors">{isEn ? "Schedule" : "Programas"}</a></li>
          <li><a href="#events-section" class="font-sans text-sm text-neutral-400 font-medium hover:text-white transition-colors">{isEn ? "Events" : "Eventos"}</a></li>
          <li><a href="#live-section" class="font-sans text-sm text-neutral-400 font-medium hover:text-white transition-colors">{isEn ? "Listen Live" : "En Vivo"}</a></li>
        </ul>
      </div>

      <!-- Links Col 2 -->
      <div class="flex flex-col gap-4">
        <h5 class="font-mono text-xs font-bold text-orange uppercase">{isEn ? "ABOUT" : "NOSOTROS"}</h5>
        <ul class="list-none flex flex-col gap-2.5">
          <li><a href="#footer" class="font-sans text-sm text-neutral-400 font-medium hover:text-white transition-colors">{isEn ? "Who We Are" : "Quiénes somos"}</a></li>
          <li><a href="#footer" class="font-sans text-sm text-neutral-400 font-medium hover:text-white transition-colors">{isEn ? "Our Team" : "Nuestro equipo"}</a></li>
          <li><a href="#footer" class="font-sans text-sm text-neutral-400 font-medium hover:text-white transition-colors">{isEn ? "Contact" : "Contacto"}</a></li>
        </ul>
      </div>

      <!-- Links Col 3 -->
      <div class="flex flex-col gap-4">
        <h5 class="font-mono text-xs font-bold text-orange uppercase">{isEn ? "LEGAL" : "LEGAL"}</h5>
        <ul class="list-none flex flex-col gap-2.5">
          <li><a href="#footer" class="font-sans text-sm text-neutral-400 font-medium hover:text-white transition-colors">{isEn ? "Terms" : "Términos y condiciones"}</a></li>
          <li><a href="#footer" class="font-sans text-sm text-neutral-400 font-medium hover:text-white transition-colors">{isEn ? "Privacy" : "Política de privacidad"}</a></li>
        </ul>
      </div>
    </div>

    <!-- Massive Outlined Footprint Brand Text (Brutalist Trend) -->
    <div class="massive-brand-text py-6 md:py-10">
      bloom radio
    </div>

    <!-- Copyright -->
    <div class="text-center pt-8 border-t border-neutral-900">
      <p class="font-mono text-[10px] text-neutral-500 tracking-wider">
        &copy; {new Date().getFullYear()} Bloom Radio. {isEn ? "All rights reserved." : "Todos los derechos reservados."}
      </p>
    </div>

  </div>
</footer>

<style>
  .massive-brand-text {
    font-family: var(--font-sans);
    font-size: 11vw;
    font-weight: 900;
    text-transform: uppercase;
    text-align: center;
    line-height: 1;
    letter-spacing: -0.06em;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.12);
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
  }
</style>

