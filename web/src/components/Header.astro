---
interface Props {
  isEn?: boolean;
}

const { isEn = true } = Astro.props;

const currentPath = Astro.url.pathname;
const esLink = isEn ? `/es${currentPath === "/" ? "" : currentPath}` : currentPath;
const enLink = isEn ? currentPath : currentPath.replace(/^\/es/, "") || "/";
---

<header class="header">
  <div class="header-container">
    <!-- Brand / Logo in lowercase bold -->
    <a href={isEn ? "/" : "/es"} class="logo">
      bloom radio®
    </a>

    <!-- Monospace centered categories mimicking the top metadata links in Mockup 1 -->
    <div class="header-meta-categories">
      <div class="category-indicator">
        <span class="indicator-dot"></span>
        <a href="#live-section" class="category-link">{isEn ? "LIVE BROADCAST" : "TRANSMISIÓN EN VIVO"}</a>
      </div>
      <a href="#programs-section" class="category-link">{isEn ? "SCHEDULE" : "PROGRAMACIÓN"}</a>
      <a href="#events-section" class="category-link">{isEn ? "EVENTS" : "EVENTOS"}</a>
    </div>

    <!-- Navigation / Actions -->
    <div class="header-actions">
      <div class="lang-switcher">
        <a href={esLink} class={`lang-btn ${!isEn ? 'active' : ''}`}>ES</a>
        <span class="lang-divider">|</span>
        <a href={enLink} class={`lang-btn ${isEn ? 'active' : ''}`}>EN</a>
      </div>
      
      <!-- Minimal "Menu" button matching top right of Mockup 1 -->
      <a href="#footer" class="menu-trigger">
        {isEn ? "Menu" : "Menú"}
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    background-color: var(--color-orange);
    color: var(--color-text-dark);
    border-bottom: 2px solid var(--color-text-dark);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-container {
    max-width: 100%;
    padding: 1.5rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* lowercase bold grotesque logo */
  .logo {
    font-family: var(--font-sans);
    font-size: 1.6rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--color-text-dark);
    text-decoration: none;
    text-transform: lowercase; /* Brutalist lowercase brand */
  }

  /* Centered monospaced categories from Mockup 1 */
  .header-meta-categories {
    display: flex;
    flex-direction: column;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-weight: 1.3;
    font-weight: 700;
  }

  .category-indicator {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .indicator-dot {
    width: 6px;
    height: 6px;
    background-color: var(--color-text-dark);
    border-radius: 50%;
  }

  .category-link {
    color: var(--color-text-dark);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .category-link:hover {
    opacity: 0.7;
  }

  /* Right-side elements */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .lang-switcher {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .lang-btn {
    color: var(--color-text-dark);
    text-decoration: none;
    padding: 0.1rem 0.3rem;
    opacity: 0.5;
  }

  .lang-btn.active {
    opacity: 1;
    border-bottom: 2px solid var(--color-text-dark);
  }

  .lang-divider {
    color: var(--color-text-dark);
    opacity: 0.3;
  }

  .menu-trigger {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-dark);
    text-decoration: none;
    border-bottom: 2px solid transparent;
  }

  .menu-trigger:hover {
    border-bottom-color: var(--color-text-dark);
  }

  @media (max-width: 768px) {
    .header-container {
      padding: 1rem 1.5rem;
    }
    .header-meta-categories {
      display: none; /* Hide categories in mobile header */
    }
  }
</style>
