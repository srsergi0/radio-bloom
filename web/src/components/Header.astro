---
interface Props {
  isEn?: boolean;
}

const { isEn = true } = Astro.props;

const currentPath = Astro.url.pathname;
const esLink = isEn ? `/es${currentPath === "/" ? "" : currentPath}` : currentPath;
const enLink = isEn ? currentPath : currentPath.replace(/^\/es/, "") || "/";
---

<header class="sticky top-0 z-50 bg-orange text-text-dark border-b-2 border-text-dark">
  <div class="max-w-full px-4 sm:px-6 md:px-12 py-4 md:py-5 flex justify-between items-center">
    <!-- Brand / Logo in lowercase bold -->
    <a href={isEn ? "/" : "/es"} class="logo text-xl sm:text-2xl font-black tracking-tighter text-text-dark no-underline lowercase">
      bloom radio®
    </a>

    <!-- Monospace centered categories mimicking the top metadata links in Mockup 1 -->
    <div class="hidden md:flex flex-col font-mono text-[11px] leading-[1.3] font-bold">
      <div class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 bg-text-dark rounded-full"></span>
        <a href="#live-section" class="text-text-dark no-underline hover:opacity-70 transition-opacity">{isEn ? "LIVE BROADCAST" : "TRANSMISIÓN EN VIVO"}</a>
      </div>
      <a href="#programs-section" class="text-text-dark no-underline hover:opacity-70 transition-opacity">{isEn ? "SCHEDULE" : "PROGRAMACIÓN"}</a>
      <a href="#events-section" class="text-text-dark no-underline hover:opacity-70 transition-opacity">{isEn ? "EVENTS" : "EVENTOS"}</a>
    </div>

    <!-- Navigation / Actions -->
    <div class="flex items-center gap-4 sm:gap-8 md:gap-10">
      <div class="font-mono text-xs sm:text-sm font-bold">
        <a href={esLink} class={`text-text-dark no-underline px-1 py-0.5 transition-all ${!isEn ? 'opacity-100 border-b-2 border-text-dark' : 'opacity-50 hover:opacity-80'}`}>ES</a>
        <span class="text-text-dark opacity-35">|</span>
        <a href={enLink} class={`text-text-dark no-underline px-1 py-0.5 transition-all ${isEn ? 'opacity-100 border-b-2 border-text-dark' : 'opacity-50 hover:opacity-80'}`}>EN</a>
      </div>
      
      <!-- Minimal "Menu" button matching top right of Mockup 1 -->
      <a href="#footer" class="font-mono text-xs sm:text-sm font-bold text-text-dark no-underline border-b-2 border-transparent hover:border-text-dark transition-all">
        {isEn ? "Menu" : "Menú"}
      </a>
    </div>
  </div>
</header>

