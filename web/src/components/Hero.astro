---
import Button from "./ui/Button.astro";

interface Props {
  isEn?: boolean;
}

const { isEn = false } = Astro.props;
---

<section class="bg-ice-blue text-text-dark border-b-2 border-text-dark max-w-full">
  <!-- Massive Typography Block -->
  <div class="px-4 sm:px-6 md:px-12 py-10 md:py-16 border-b-2 border-text-dark">
    <h1 class="text-[12vw] lg:text-[8vw] font-black leading-[0.85] tracking-tighter uppercase text-text-dark">
      <span>Bloom Radio</span>
    </h1>
  </div>

  <!-- 3-Column Grid divided by solid black borders -->
  <div class="grid grid-cols-1 lg:grid-cols-3 max-w-full">
    <!-- Column 1: Play Radio Action -->
    <div class="p-6 sm:p-8 md:p-12 lg:border-r-2 border-b-2 lg:border-b-0 border-text-dark flex items-center lg:items-start justify-center lg:justify-start">
      <Button href="#live-section" variant="text" class="font-mono text-base md:text-lg font-bold text-text-dark inline-flex items-center gap-2 py-2">
        <span class="text-xs">▶</span>
        {isEn ? "Play Radio" : "Escuchar Radio"}
      </Button>
    </div>

    <!-- Column 2: Music Vibe Details -->
    <div class="p-6 sm:p-8 md:p-12 border-b-2 lg:border-b-0 lg:border-r-2 border-text-dark flex flex-col justify-start">
      <p class="font-sans text-[13px] md:text-sm leading-relaxed text-text-dark text-justify">
        {
          isEn
            ? "At Bloom Radio, we transcend boundaries to bring you a sonic journey that stretches beyond the horizon. With an eclectic mix of lofi beats, ambient textures, and organic field recordings, we are your ultimate destination for soul-stirring melodies and peaceful soundscapes."
            : "En Bloom Radio, trascendemos los límites sonoros para ofrecerte un viaje acústico único. Con una mezcla curada de beats lofi, texturas ambient y grabaciones de campo orgánicas, somos tu destino definitivo para melodías inspiradoras y paisajes sonoros pacíficos."
        }
      </p>
    </div>

    <!-- Column 3: Purpose Details -->
    <div class="p-6 sm:p-8 md:p-12 flex flex-col justify-start">
      <p class="font-sans text-[13px] md:text-sm leading-relaxed text-text-dark text-justify">
        {
          isEn
            ? "Our station is more than just a platform for music - it's a gateway to exploration, focus, and deep relaxation. Whether you are seeking focus for study, stress relief, or underground gems, Bloom Radio promises to ignite your passion for sound and elevate your daily environment."
            : "Nuestra estación es más que una simple plataforma musical: es una puerta al enfoque, la exploración y la relajación profunda. Ya sea que busques concentrarte para estudiar, aliviar el estrés o descubrir joyas sonoras independientes, Bloom Radio promete elevar tu día a día."
        }
      </p>
    </div>
  </div>
</section>

