---
import Player from './Player.astro';
import Card from './ui/Card.astro';

interface Props {
  isEn?: boolean;
}

const { isEn = false } = Astro.props;

const schedule = [
  {
    time: "10:00",
    title: "Morning Bloom",
    host: "Samantha Lee",
    active: true
  },
  {
    time: "14:00",
    title: "Top Bloom",
    host: "Alex Martin",
    active: false
  },
  {
    time: "18:00",
    title: "Bloom Beats",
    host: "DJ Vibe",
    active: false
  },
  {
    time: "22:00",
    title: "Night Bloom",
    host: "Luna Sky",
    active: false
  }
];
---

<section class="px-4 sm:px-6 md:px-12 py-10 md:py-20 max-w-full bg-black border-b-2 border-white" id="live-section">
  <div class="max-w-[1200px] mx-auto">
    <div class="mb-8 md:mb-12">
      <div>
        <span class="font-mono text-xs sm:text-sm font-bold text-orange">[ {isEn ? "LIVE BROADCAST" : "EN VIVO AHORA"} ]</span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-8 lg:gap-12 items-stretch">
      <!-- Player on the Left -->
      <div class="w-full">
        <Player isEn={isEn} />
      </div>

      <!-- Schedule on the Right -->
      <Card theme="dark" shadow={true} class="schedule-brutalist-card p-0! overflow-hidden">
        <div class="flex flex-col h-full justify-stretch">
          {schedule.map((show) => (
            <div class={`flex items-center gap-4 px-5 sm:px-8 py-5 md:py-6 border-b-2 border-white last:border-b-0 transition-all ${show.active ? 'bg-orange text-black' : 'bg-transparent text-white hover:bg-white/5'}`}>
              <div class="font-mono text-base font-bold w-16 flex-shrink-0">{show.time}</div>
              <div class="flex-grow min-w-0">
                <h4 class="font-sans text-base md:text-lg font-black uppercase tracking-tight truncate">{show.title}</h4>
                <p class="font-mono text-xs opacity-85 truncate">
                  {isEn ? "with " : "con "}
                  <span class="font-bold">{show.host}</span>
                </p>
              </div>
              {show.active && (
                <div class="flex items-end gap-1 h-3.5 flex-shrink-0">
                  <div class="w-[3px] h-1.5 bg-black eq-dot origin-bottom"></div>
                  <div class="w-[3px] h-3.5 bg-black eq-dot origin-bottom"></div>
                  <div class="w-[3px] h-2.5 bg-black eq-dot origin-bottom"></div>
                </div>
              )}
            </div>
          ))}
        </div>
      </Card>
    </div>
  </div>
</section>

<style>
  .schedule-brutalist-card :global(.brutalist-card) {
    padding: 0 !important;
  }
  
  .eq-dot {
    animation: eq-bounce-black 0.6s ease-in-out infinite alternate;
  }

  .eq-dot:nth-child(2) { height: 14px; animation-duration: 0.4s; }
  .eq-dot:nth-child(3) { height: 10px; animation-duration: 0.5s; }

  @keyframes eq-bounce-black {
    from { transform: scaleY(0.4); }
    to { transform: scaleY(1.2); }
  }
</style>

