---
interface Props {
  isEn?: boolean;
}

const { isEn = false } = Astro.props;
---

<div class="synth-player" id="live-player-card">
  <!-- Top Status Panel (Monospace Hardware Stats) -->
  <div class="synth-status-bar">
    <div class="status-left">
      <span class="status-indicator"></span>
      <span class="status-label mono-tag">SIGNAL: ONLINE</span>
    </div>
    <div class="status-right">
      <span class="status-data mono-tag">320KBPS / MP3</span>
      <span class="status-data mono-tag">104.2MHZ</span>
    </div>
  </div>

  <!-- Main Hardware Screen -->
  <div class="synth-screen">
    <!-- Scrolling LED Marquee for track info -->
    <div class="ticker-wrap">
      <div class="ticker-content" id="track-marquee">
        {isEn ? "LOADING LIVE SIGNAL BROADCAST..." : "CARGANDO EMISIÓN EN DIRECTO..."}
      </div>
    </div>

    <!-- LED Spectrometer Matrix (6 rows x 12 columns) -->
    <div class="led-matrix" id="led-matrix">
      <!-- 12 Columns -->
      {Array.from({ length: 12 }).map((_, colIdx) => (
        <div class="matrix-col" style={`--col-delay: ${colIdx * 0.15}s`}>
          {Array.from({ length: 6 }).map((_, cellIdx) => (
            <div class="matrix-cell" style={`--cell-idx: ${cellIdx}`}></div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- Hardware Controls Panel -->
  <div class="synth-controls">
    <!-- Giant mechanical play key -->
    <button class="synth-play-key" id="play-btn" aria-label="Play/Pause">
      <div class="key-inner">
        <svg class="play-icon" id="play-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg class="pause-icon hidden" id="pause-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </div>
    </button>

    <!-- Fader / Volume Control Section -->
    <div class="synth-fader-block">
      <div class="fader-label-row">
        <span class="mono-tag">{isEn ? "VOL" : "VOL"}</span>
        <button class="mute-btn" id="volume-btn" aria-label="Mute/Unmute">
          <svg class="volume-icon" id="volume-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
          </svg>
        </button>
      </div>
      <div class="fader-track-container">
        <input type="range" min="0" max="1" step="0.05" value="0.8" class="synth-slider" id="volume-slider" aria-label="Volume Slider" />
      </div>
    </div>

    <!-- Description Block -->
    <div class="synth-info-block">
      <div class="show-meta">
        <span class="now-playing-tag mono-tag">[ {isEn ? "ACTIVE SHOW" : "PROGRAMA ACTIVO"} ]</span>
        <h4 id="track-title-text" class="show-title">Morning Bloom</h4>
        <p id="track-artist-text" class="show-host">con Samantha Lee</p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Outer casing of the synthesizer unit */
  .synth-player {
    background-color: #000000;
    border: 3px solid #ffffff;
    padding: 1.75rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    box-shadow: 8px 8px 0px #ffffff;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .synth-player:hover {
    transform: translate(-2px, -2px);
    box-shadow: 10px 10px 0px #ffffff;
  }

  /* Casing Status Bar */
  .synth-status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #ffffff;
    padding-bottom: 0.75rem;
  }

  .status-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-indicator {
    width: 8px;
    height: 8px;
    background-color: #00ff00;
    border-radius: 50%;
    box-shadow: 0 0 6px #00ff00;
    animation: pulse-indicator 1.5s infinite alternate;
  }

  @keyframes pulse-indicator {
    from { opacity: 0.4; }
    to { opacity: 1; }
  }

  .status-right {
    display: flex;
    gap: 1rem;
  }

  .status-label, .status-data {
    color: var(--color-orange);
    font-weight: 700;
  }

  .status-data {
    opacity: 0.7;
  }

  /* Main LED Screen */
  .synth-screen {
    background-color: #07040a;
    border: 2px solid #ffffff;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* LED Ticker Marquee screen */
  .ticker-wrap {
    overflow: hidden;
    white-space: nowrap;
    border: 2px solid #ffffff;
    background-color: #000000;
    padding: 0.5rem;
    color: var(--color-orange);
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
  }

  .ticker-content {
    display: inline-block;
    padding-left: 100%;
    animation: marquee-scroll 12s linear infinite;
  }

  @keyframes marquee-scroll {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-100%, 0, 0); }
  }

  /* LED Matrix spectrometer */
  .led-matrix {
    display: flex;
    justify-content: space-between;
    height: 48px;
    opacity: 0.15;
    transition: opacity 0.3s ease;
  }

  .led-matrix.active {
    opacity: 1;
  }

  .matrix-col {
    display: flex;
    flex-direction: column-reverse; /* stack from bottom up */
    gap: 2px;
    width: 7%;
  }

  .matrix-cell {
    height: 6px;
    background-color: #1a1523;
  }

  /* When playing, columns bounce */
  .led-matrix.active .matrix-col .matrix-cell {
    animation: col-flash 1s steps(6) infinite alternate;
    animation-delay: var(--col-delay);
  }

  /* Cells light up progressively based on index */
  @keyframes col-flash {
    0% {
      background-color: #1a1523;
    }
    100% {
      /* Cells at different heights light up with color gradient */
      background-color: var(--color-orange);
    }
  }

  /* Add color coding to top rows of LED matrix */
  .led-matrix.active .matrix-cell:nth-child(n+5) {
    animation-name: col-flash-alert;
  }

  @keyframes col-flash-alert {
    0% { background-color: #1a1523; }
    100% { background-color: var(--accent); }
  }

  /* Casing Control Area */
  .synth-controls {
    display: grid;
    grid-template-columns: 80px 100px 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  /* Synthesizer Mechanical key */
  .synth-play-key {
    width: 80px;
    height: 80px;
    background-color: var(--color-orange);
    border: 3px solid #000000;
    outline: 2px solid #ffffff;
    cursor: pointer;
    position: relative;
    padding: 0;
    transition: transform 0.1s, box-shadow 0.1s;
    box-shadow: 4px 4px 0px #ffffff;
  }

  .synth-play-key:hover {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0px #ffffff;
  }

  .synth-play-key:active {
    transform: translate(3px, 3px);
    box-shadow: 1px 1px 0px #ffffff;
  }

  .key-inner {
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #000000;
  }

  .key-inner svg {
    width: 32px;
    height: 32px;
  }

  /* Physical Slide Pot (Volume Fader) */
  .synth-fader-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .fader-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #ffffff;
  }

  .mute-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0;
  }

  .mute-btn:hover {
    color: #ffffff;
  }

  .mute-btn svg {
    width: 16px;
    height: 16px;
  }

  .fader-track-container {
    height: 40px;
    display: flex;
    align-items: center;
  }

  /* Custom styled brutalist slide pot */
  .synth-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    background: #ffffff;
    outline: none;
    border: 1px solid #000000;
  }

  .synth-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 24px;
    background-color: var(--color-orange);
    border: 2px solid #ffffff;
    cursor: pointer;
  }

  /* Info Column */
  .synth-info-block {
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-left: 2px solid #ffffff;
    padding-left: 1.5rem;
    height: 80px;
  }

  .now-playing-tag {
    color: var(--color-orange);
    margin-bottom: 0.15rem;
    display: block;
  }

  .show-title {
    font-size: 1.35rem;
    font-weight: 900;
    color: #ffffff;
    font-family: var(--font-sans);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .show-host {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .hidden {
    display: none;
  }

  @media (max-width: 768px) {
    .synth-controls {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
    }
    .synth-fader-block {
      display: none; /* Hide fader block in mobile width */
    }
    .synth-info-block {
      border-left: none;
      padding-left: 0;
    }
  }
</style>

<script>
  const STREAM_URL = "https://radio-bloom.taptapp.xyz/radiobloom.mp3";
  const API_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
    ? 'http://localhost:9876'
    : '';

  const audio = new Audio();
  audio.preload = "none";

  const playBtn = document.getElementById("play-btn");
  const playIcon = document.getElementById("play-icon");
  const pauseIcon = document.getElementById("pause-icon");
  const ledMatrix = document.getElementById("led-matrix");
  const trackMarquee = document.getElementById("track-marquee");
  
  const volumeBtn = document.getElementById("volume-btn");
  const volumeIcon = document.getElementById("volume-icon");
  const volumeSlider = document.getElementById("volume-slider") as HTMLInputElement;

  const trackTitleText = document.getElementById("track-title-text");
  const trackArtistText = document.getElementById("track-artist-text");

  let isPlaying = false;
  let isMuted = false;
  let previousVolume = 0.8;

  audio.volume = parseFloat(volumeSlider?.value || "0.8");

  function togglePlay() {
    if (isPlaying) {
      audio.pause();
      audio.src = ""; 
      isPlaying = false;
      playIcon?.classList.remove("hidden");
      pauseIcon?.classList.add("hidden");
      ledMatrix?.classList.remove("active");
    } else {
      audio.src = STREAM_URL;
      audio.load();
      audio.play().catch(err => console.error("Audio playback error:", err));
      isPlaying = true;
      playIcon?.classList.add("hidden");
      pauseIcon?.classList.remove("hidden");
      ledMatrix?.classList.add("active");
    }
  }

  playBtn?.addEventListener("click", togglePlay);

  volumeSlider?.addEventListener("input", (e) => {
    const target = e.target as HTMLInputElement;
    const val = parseFloat(target.value);
    audio.volume = val;
    isMuted = val === 0;
    updateVolumeIcon(val);
  });

  volumeBtn?.addEventListener("click", () => {
    if (isMuted) {
      audio.volume = previousVolume;
      if (volumeSlider) volumeSlider.value = previousVolume.toString();
      isMuted = false;
    } else {
      previousVolume = audio.volume;
      audio.volume = 0;
      if (volumeSlider) volumeSlider.value = "0";
      isMuted = true;
    }
    updateVolumeIcon(audio.volume);
  });

  function updateVolumeIcon(vol: number) {
    if (!volumeIcon) return;
    if (vol === 0 || isMuted) {
      volumeIcon.innerHTML = `<path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.21.05-.42.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>`;
    } else {
      volumeIcon.innerHTML = `<path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>`;
    }
  }

  async function fetchMetadata() {
    try {
      const response = await fetch(`${API_BASE}/api/stream`);
      if (response.ok) {
        const json = await response.json();
        if (json.ok && json.data) {
          const title = json.data.title || "Morning Bloom";
          const artist = json.data.artist || "Samantha Lee";
          
          // Build ticker message
          const lang = document.documentElement.lang;
          const message = lang === 'en'
            ? `LIVE NOW: ${title.toUpperCase()} BY ${artist.toUpperCase()} - SIGNAL STATUS: EXCELLENT - STREAM RATE: 320 KBPS STABLE - `
            : `EN EMISIÓN: ${title.toUpperCase()} POR ${artist.toUpperCase()} - ESTADO DE SEÑAL: EXCELENTE - TASA DE BITS: 320 KBPS ESTABLE - `;
          
          if (trackMarquee && trackMarquee.innerText !== message) {
            trackMarquee.innerText = message;
          }
          if (trackTitleText && trackTitleText.innerText !== title) {
            trackTitleText.innerText = title;
          }
          
          const prefix = lang === 'en' ? 'with' : 'con';
          const fullArtistText = `${prefix} ${artist}`;
          if (trackArtistText && trackArtistText.innerText !== fullArtistText) {
            trackArtistText.innerText = fullArtistText;
          }
        }
      }
    } catch (err) {
      console.warn("Could not fetch metadata:", err);
    }
  }

  fetchMetadata();
  setInterval(fetchMetadata, 10000);
</script>
