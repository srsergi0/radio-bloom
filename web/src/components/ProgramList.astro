---
import Card from './ui/Card.astro';

interface Props {
  isEn?: boolean;
}

const { isEn = false } = Astro.props;

const shows = [
  {
    idx: "[ 01 ]",
    title: "Morning Bloom",
    time: isEn ? "Monday to Friday 10:00 AM" : "Lunes a Viernes 10:00 AM",
  },
  {
    idx: "[ 02 ]",
    title: "Top Bloom",
    time: isEn ? "Monday to Friday 02:00 PM" : "Lunes a Viernes 02:00 PM",
  },
  {
    idx: "[ 03 ]",
    title: "Bloom Beats",
    time: isEn ? "Monday to Friday 06:00 PM" : "Lunes a Viernes 06:00 PM",
  },
  {
    idx: "[ 04 ]",
    title: "Night Bloom",
    time: isEn ? "Monday to Thursday 10:00 PM" : "Lunes a Jueves 10:00 PM",
  }
];
---

<section class="px-4 sm:px-6 md:px-12 py-10 md:py-20 bg-ice-blue text-text-dark border-b-2 border-text-dark max-w-full" id="programs-section">
  <div class="max-w-[1200px] mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 md:gap-0 mb-8 md:mb-16">
      <div>
        <span class="font-mono text-xs sm:text-sm font-bold text-orange block mb-2">[ {isEn ? "WEEKLY SCHEDULE" : "PROGRAMACIÓN SEMANAL"} ]</span>
        <h2 class="text-3xl md:text-5xl font-black tracking-tighter leading-none uppercase">{isEn ? "Always something for you" : "Siempre hay algo para ti"}</h2>
      </div>
      <a href="#programs-section" class="font-mono text-xs sm:text-sm font-bold text-text-dark no-underline flex items-center gap-1.5 border-b-2 border-text-dark pb-1 hover:translate-x-0.5 hover:-translate-y-0.5 transition-all">
        {isEn ? "VIEW ALL SHOWS" : "VER TODOS LOS PROGRAMAS"}
        <span class="text-base">↗</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {shows.map((show) => (
        <Card theme="light" shadow={true} class="p-4! overflow-hidden">
          <div class="flex items-center gap-4 sm:gap-6 w-full">
            <!-- Brutalist Numbered Cover -->
            <div class="w-16 h-16 sm:w-[90px] sm:h-[90px] bg-black text-white flex justify-center items-center border-2 border-black flex-shrink-0">
              <span class="font-mono text-sm sm:text-lg font-bold">{show.idx}</span>
            </div>
            
            <div class="flex-grow min-w-0">
              <h4 class="text-lg sm:text-xl font-black tracking-tight text-text-dark mb-1 truncate uppercase">{show.title}</h4>
              <p class="text-[11px] sm:text-xs text-neutral-600 font-mono">{show.time}</p>
            </div>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>

