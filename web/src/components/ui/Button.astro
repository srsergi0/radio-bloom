---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'button'>, HTMLAttributes<'a'> {
  variant?: 'solid' | 'outline' | 'text';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const {
  variant = 'solid',
  size = 'md',
  href,
  class: className = '',
  ...rest
} = Astro.props;

const Element = href ? 'a' : 'button';
const classes = `brutalist-btn btn-${variant} btn-${size} ${className}`;
---

<!-- @ts-ignore -->
<Element href={href} class={classes} {...rest}>
  <slot />
</Element>

<style>
  .brutalist-btn {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s, transform 0.15s, box-shadow 0.15s;
    text-decoration: none;
    border-radius: 0;
    outline: none;
    text-align: center;
    letter-spacing: 0.02em;
  }

  .btn-solid {
    background-color: var(--color-orange);
    color: var(--color-text-dark);
    border: 3px solid var(--color-text-dark);
    box-shadow: 5px 5px 0px var(--color-text-dark);
  }
  .btn-solid:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0px var(--color-text-dark);
  }
  .btn-solid:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px var(--color-text-dark);
  }

  .btn-outline {
    background-color: transparent;
    color: currentColor;
    border: 3px solid currentColor;
    box-shadow: 5px 5px 0px currentColor;
  }
  .btn-outline:hover {
    background-color: currentColor;
    filter: invert(1);
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0px currentColor;
  }
  .btn-outline:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px currentColor;
  }

  .btn-text {
    background-color: transparent;
    color: currentColor;
    border: none;
    padding: 0.25rem 0.5rem;
    border-bottom: 3px solid transparent;
  }
  .btn-text:hover {
    border-bottom-color: currentColor;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
  }
  .btn-md {
    padding: 0.75rem 1.5rem;
    font-size: 0.85rem;
  }
  .btn-lg {
    padding: 1rem 2rem;
    font-size: 0.95rem;
  }
</style>
