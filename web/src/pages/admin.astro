---
import Layout from "../layouts/Layout.astro";
---

<Layout title="AI DJ Manager - Bloom Radio" lang="en">
  <div class="max-w-7xl mx-auto px-5 md:px-10 py-10">
    <div
      class="mb-10 brutalist-border p-6 bg-orange brutalist-shadow text-text-dark"
    >
      <h1 class="text-4xl md:text-5xl font-black mb-2 tracking-tight">
        AI DJ & LOCUTOR MANAGER
      </h1>
      <p class="font-mono text-sm font-bold opacity-90">
        Configure multiple AI voices, customize their unique personalities, and
        schedule programs.
      </p>
    </div>

    <!-- Alert Container for Errors/Success -->
    <div
      id="global-alert"
      class="hidden mb-6 brutalist-border p-4 font-mono text-sm font-bold brutalist-shadow"
    >
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- COLUMN 1: Locutors List & Management (8 cols on large screen) -->
      <div class="lg:col-span-8 flex flex-col gap-6">
        <h2 class="text-2xl font-black tracking-tight text-white mb-2">
          ACTIVE AI VOICE TALENT
        </h2>

        <div id="locutors-container" class="flex flex-col gap-6">
          <!-- Locutor cards will be dynamically injected here -->
          <div
            class="p-6 brutalist-border bg-white text-text-dark font-mono text-sm"
          >
            Loading AI talent pool...
          </div>
        </div>
      </div>

      <!-- COLUMN 2: Create / Edit Locutor (4 cols) -->
      <div class="lg:col-span-4 flex flex-col gap-6">
        <div
          class="brutalist-border p-6 bg-ice-blue text-text-dark brutalist-shadow"
        >
          <h2 class="text-xl font-black tracking-tight mb-4" id="form-title">
            ADD AI LOCUTOR
          </h2>

          <form
            id="locutor-form"
            class="flex flex-col gap-4 font-mono text-xs font-bold"
          >
            <input type="hidden" id="locutor-id" />

            <div class="flex flex-col gap-1">
              <label for="locutor-name" class="uppercase">DJ Name / Alias</label
              >
              <input
                type="text"
                id="locutor-name"
                required
                placeholder="e.g. DJ Bloom, Alexa Neural"
                class="brutalist-input p-2 text-sm bg-white"
              />
            </div>

            <div class="flex flex-col gap-1">
              <label for="locutor-voice" class="uppercase"
                >Neural Voice (Edge-TTS)</label
              >
              <select
                id="locutor-voice"
                required
                class="brutalist-input p-2 text-sm bg-white"
              >
                <option value="es-PE-AlexNeural"
                  >es-PE-AlexNeural (Peru, Male)</option
                >
                <option value="es-PE-CamilaNeural"
                  >es-PE-CamilaNeural (Peru, Female)</option
                >
                <option value="es-ES-AlvaroNeural" selected
                  >es-ES-AlvaroNeural (Spain, Male)</option
                >
                <option value="es-ES-ElviraNeural"
                  >es-ES-ElviraNeural (Spain, Female)</option
                >
                <option value="es-MX-JorgeNeural"
                  >es-MX-JorgeNeural (Mexico, Male)</option
                >
                <option value="es-MX-DaliaNeural"
                  >es-MX-DaliaNeural (Mexico, Female)</option
                >
                <option value="es-AR-TomasNeural"
                  >es-AR-TomasNeural (Argentina, Male)</option
                >
                <option value="es-AR-ElenaNeural"
                  >es-AR-ElenaNeural (Argentina, Female)</option
                >
                <option value="en-US-GuyNeural"
                  >en-US-GuyNeural (US English, Male)</option
                >
                <option value="en-US-AriaNeural"
                  >en-US-AriaNeural (US English, Female)</option
                >
              </select>
            </div>

            <div class="flex flex-col gap-1">
              <label for="locutor-personality" class="uppercase"
                >On-Air Personality / Prompt</label
              >
              <textarea
                id="locutor-personality"
                required
                rows="6"
                placeholder="Describe how they behave, how they connect with music, their style, tone, and catchphrases..."
                class="brutalist-input p-2 text-sm bg-white font-mono"
              ></textarea>
            </div>

            <div class="flex gap-4 py-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="locutor-active"
                  checked
                  class="w-4 h-4 accent-orange"
                />
                <span>ACTIVE ON-AIR</span>
              </label>

              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="locutor-default"
                  class="w-4 h-4 accent-orange"
                />
                <span>DEFAULT FALLBACK</span>
              </label>
            </div>

            <div class="flex gap-2 mt-2">
              <button
                type="submit"
                class="flex-grow brutalist-button bg-orange text-text-dark p-3 text-sm font-black uppercase"
              >
                SAVE DJ
              </button>
              <button
                type="button"
                id="cancel-edit"
                class="hidden brutalist-button bg-white text-text-dark p-3 text-sm font-black uppercase"
              >
                CANCEL
              </button>
            </div>
          </form>
        </div>

        <!-- Add Schedule Panel (hidden until a DJ is loaded/selected for scheduling) -->
        <div
          id="schedule-panel"
          class="hidden brutalist-border p-6 bg-white text-text-dark brutalist-shadow"
        >
          <h2 class="text-xl font-black tracking-tight mb-2">
            ADD PROGRAM SCHEDULE
          </h2>
          <p
            id="schedule-dj-name"
            class="font-mono text-xs font-bold text-orange mb-4"
          >
          </p>

          <form
            id="schedule-form"
            class="flex flex-col gap-4 font-mono text-xs font-bold"
          >
            <div class="flex flex-col gap-1">
              <label for="sched-type" class="uppercase">Recurrence</label>
              <select
                id="sched-type"
                required
                class="brutalist-input p-2 text-sm bg-white"
              >
                <option value="daily">DAILY (Every day)</option>
                <option value="weekly">WEEKLY (Once a week)</option>
              </select>
            </div>

            <div class="flex flex-col gap-1" id="weekly-day-group">
              <label for="sched-day" class="uppercase">Day of the Week</label>
              <select
                id="sched-day"
                class="brutalist-input p-2 text-sm bg-white"
              >
                <option value="1">Lunes / Monday</option>
                <option value="2">Martes / Tuesday</option>
                <option value="3">Miércoles / Wednesday</option>
                <option value="4">Jueves / Thursday</option>
                <option value="5">Viernes / Friday</option>
                <option value="6">Sábado / Saturday</option>
                <option value="0">Domingo / Sunday</option>
              </select>
            </div>

            <div class="grid grid-cols-2 gap-2">
              <div class="flex flex-col gap-1">
                <label for="sched-time" class="uppercase">Start Time</label>
                <input
                  type="time"
                  id="sched-time"
                  required
                  class="brutalist-input p-2 text-sm bg-white"
                />
              </div>

              <div class="flex flex-col gap-1">
                <label for="sched-duration" class="uppercase"
                  >Duration (min)</label
                >
                <input
                  type="number"
                  id="sched-duration"
                  required
                  min="5"
                  max="1440"
                  value="60"
                  class="brutalist-input p-2 text-sm bg-white"
                />
              </div>
            </div>

            <button
              type="submit"
              class="brutalist-button bg-orange text-text-dark p-3 text-sm font-black uppercase mt-2"
            >
              ADD SHOWTIME
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .brutalist-border {
    border: 3px solid #000000;
  }

  .brutalist-shadow {
    box-shadow: 6px 6px 0px #000000;
  }

  .brutalist-input {
    border: 3px solid #000000;
    outline: none;
    transition:
      transform 0.1s,
      box-shadow 0.1s;
    font-weight: bold;
    border-radius: 0;
  }

  .brutalist-input:focus {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0px #000000;
  }

  .brutalist-button {
    border: 3px solid #000000;
    box-shadow: 4px 4px 0px #000000;
    cursor: pointer;
    transition:
      transform 0.1s,
      box-shadow 0.1s;
    border-radius: 0;
    text-align: center;
  }

  .brutalist-button:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px #000000;
  }

  .brutalist-button:active {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0px #000000;
  }
</style>

<script is:inline>
  let locutors = [];
  let selectedLocutorId = null;

  const locutorsContainer = document.getElementById("locutors-container");
  const locutorForm = document.getElementById("locutor-form");
  const cancelEditBtn = document.getElementById("cancel-edit");
  const formTitle = document.getElementById("form-title");

  const schedulePanel = document.getElementById("schedule-panel");
  const scheduleDjName = document.getElementById("schedule-dj-name");
  const scheduleForm = document.getElementById("schedule-form");
  const schedType = document.getElementById("sched-type");
  const weeklyDayGroup = document.getElementById("weekly-day-group");

  const alertContainer = document.getElementById("global-alert");

  // Show status alerts (error / success)
  function showAlert(msg, type = "success") {
    alertContainer.textContent = msg.toUpperCase();
    alertContainer.className = `mb-6 brutalist-border p-4 font-mono text-sm font-bold brutalist-shadow ${
      type === "error" ? "bg-orange text-black" : "bg-ice-blue text-black"
    }`;
    alertContainer.classList.remove("hidden");
    window.scrollTo({ top: 0, behavior: "smooth" });

    // Auto hide after 6 seconds
    setTimeout(() => {
      alertContainer.classList.add("hidden");
    }, 6000);
  }

  // Toggle weekly day select box
  schedType.addEventListener("change", () => {
    if (schedType.value === "weekly") {
      weeklyDayGroup.classList.remove("hidden");
    } else {
      weeklyDayGroup.classList.add("hidden");
    }
  });

  // Load active voice talents from backend
  async function loadLocutors() {
    try {
      const res = await fetch("/api/locutors");
      const json = await res.json();
      if (json.ok) {
        locutors = json.data;
        renderLocutors();
      } else {
        showAlert(json.error || "Failed to load locutors", "error");
      }
    } catch (err) {
      showAlert(err.message, "error");
    }
  }

  // Render cards in the UI
  function renderLocutors() {
    if (locutors.length === 0) {
      locutorsContainer.innerHTML = `
        <div class="p-6 brutalist-border bg-white text-text-dark font-mono text-sm brutalist-shadow">
          NO AI LOCUTORS REGISTERED YET. USE THE FORM ON THE RIGHT TO CREATE YOUR FIRST TALENT!
        </div>
      `;
      return;
    }

    const dayNames = [
      "Sunday",
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
    ];

    locutorsContainer.innerHTML = locutors
      .map((loc) => {
        const schedulesHtml =
          loc.schedules && loc.schedules.length > 0
            ? loc.schedules
                .map(
                  (s) => `
                <div class="flex justify-between items-center bg-ice-blue p-2 border border-black text-xs font-bold">
                  <span>
                    ${s.type.toUpperCase()}: 
                    ${s.type === "weekly" ? dayNames[s.dayOfWeek] + " " : ""}
                    at ${s.startHour} (${s.duration} min)
                  </span>
                  <button 
                    type="button" 
                    data-locutor-id="${loc.id}" 
                    data-schedule-id="${s.id}" 
                    class="delete-sched-btn text-orange hover:text-black border border-orange hover:bg-orange px-2 py-0.5"
                  >
                    × REMOVE
                  </button>
                </div>
              `,
                )
                .join("")
            : `<p class="text-xs italic text-gray-500">No scheduled program timeslots. Will play only if set as Default fallback.</p>`;

        return `
          <div class="brutalist-border p-6 bg-white text-text-dark brutalist-shadow flex flex-col gap-4">
            <div class="flex justify-between items-start border-b-2 border-black pb-3">
              <div>
                <h3 class="text-2xl font-black">${loc.name.toUpperCase()}</h3>
                <p class="font-mono text-xs font-bold text-gray-600 mt-1">VOICE: ${loc.voice}</p>
              </div>
              <div class="flex gap-2">
                ${
                  loc.isActive
                    ? `<span class="bg-orange text-black border border-black font-mono text-[10px] font-black px-2 py-1">ON-AIR ACTIVE</span>`
                    : `<span class="bg-gray-200 text-gray-600 border border-gray-400 font-mono text-[10px] font-bold px-2 py-1">OFF-AIR</span>`
                }
                ${
                  loc.isDefault
                    ? `<span class="bg-ice-blue text-black border border-black font-mono text-[10px] font-black px-2 py-1">DEFAULT FALLBACK</span>`
                    : ""
                }
              </div>
            </div>

            <div class="font-mono text-xs">
              <strong class="uppercase text-gray-600">PERSONALITY PROMPT:</strong>
              <p class="mt-1 bg-gray-50 p-3 border border-black whitespace-pre-wrap leading-relaxed">${loc.personality}</p>
            </div>

            <div class="font-mono mt-2">
              <strong class="uppercase text-gray-600 text-xs">PROGRAMS & AIR TIMES:</strong>
              <div class="flex flex-col gap-2 mt-2">
                ${schedulesHtml}
              </div>
            </div>

            <div class="flex gap-2 mt-4 font-mono text-xs">
              <button 
                type="button" 
                data-id="${loc.id}" 
                class="edit-loc-btn brutalist-button bg-ice-blue p-2 font-bold uppercase flex-grow"
              >
                ✏️ EDIT DETAILS
              </button>
              <button 
                type="button" 
                data-id="${loc.id}" 
                data-name="${loc.name}" 
                class="manage-sched-btn brutalist-button bg-orange p-2 font-bold uppercase flex-grow"
              >
                📅 ADD SCHEDULE
              </button>
              <button 
                type="button" 
                data-id="${loc.id}" 
                class="delete-loc-btn text-white bg-black p-2 font-bold uppercase px-4 border-2 border-black"
              >
                DELETE DJ
              </button>
            </div>
          </div>
        `;
      })
      .join("");

    // Bind event listeners to dynamic buttons
    document.querySelectorAll(".edit-loc-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const id = e.target.getAttribute("data-id");
        editLocutor(id);
      });
    });

    document.querySelectorAll(".manage-sched-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const id = e.target.getAttribute("data-id");
        const name = e.target.getAttribute("data-name");
        openSchedulePlanner(id, name);
      });
    });

    document.querySelectorAll(".delete-loc-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const id = e.target.getAttribute("data-id");
        if (
          confirm(
            "Are you sure you want to delete this AI DJ? All schedules will be removed.",
          )
        ) {
          deleteLocutor(id);
        }
      });
    });

    document.querySelectorAll(".delete-sched-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const locId = e.target.getAttribute("data-locutor-id");
        const schedId = e.target.getAttribute("data-schedule-id");
        deleteSchedule(locId, schedId);
      });
    });
  }

  // Populate locutor edit form
  function editLocutor(id) {
    const loc = locutors.find((l) => l.id === id);
    if (!loc) return;

    selectedLocutorId = id;
    formTitle.textContent = "EDIT AI LOCUTOR";
    document.getElementById("locutor-id").value = loc.id;
    document.getElementById("locutor-name").value = loc.name;
    document.getElementById("locutor-voice").value = loc.voice;
    document.getElementById("locutor-personality").value = loc.personality;
    document.getElementById("locutor-active").checked = loc.isActive;
    document.getElementById("locutor-default").checked = loc.isDefault;

    cancelEditBtn.classList.remove("hidden");
    document.getElementById("locutor-name").focus();
  }

  // Clear locutor form
  function resetLocutorForm() {
    selectedLocutorId = null;
    formTitle.textContent = "ADD AI LOCUTOR";
    locutorForm.reset();
    document.getElementById("locutor-id").value = "";
    document.getElementById("locutor-active").checked = true;
    document.getElementById("locutor-default").checked = false;
    cancelEditBtn.classList.add("hidden");
  }

  cancelEditBtn.addEventListener("click", resetLocutorForm);

  // Form submit for locutors
  locutorForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const id = document.getElementById("locutor-id").value;
    const name = document.getElementById("locutor-name").value;
    const voice = document.getElementById("locutor-voice").value;
    const personality = document.getElementById("locutor-personality").value;
    const isActive = document.getElementById("locutor-active").checked;
    const isDefault = document.getElementById("locutor-default").checked;

    const payload = { name, voice, personality, isActive, isDefault };

    try {
      let res;
      if (id) {
        // Edit existing
        res = await fetch(`/api/locutors/${id}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
      } else {
        // Create new
        res = await fetch("/api/locutors", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
      }

      const json = await res.json();
      if (json.ok) {
        showAlert(`DJ ${name} saved successfully.`);
        resetLocutorForm();
        loadLocutors();
      } else {
        showAlert(json.error || "Error saving locutor", "error");
      }
    } catch (err) {
      showAlert(err.message, "error");
    }
  });

  // Delete locutor
  async function deleteLocutor(id) {
    try {
      const res = await fetch(`/api/locutors/${id}`, { method: "DELETE" });
      const json = await res.json();
      if (json.ok) {
        showAlert("DJ deleted successfully.");
        if (selectedLocutorId === id) resetLocutorForm();
        if (schedulePanel.getAttribute("data-current-loc-id") === id) {
          schedulePanel.classList.add("hidden");
        }
        loadLocutors();
      } else {
        showAlert(json.error || "Error deleting DJ", "error");
      }
    } catch (err) {
      showAlert(err.message, "error");
    }
  }

  // Open schedule form panel
  function openSchedulePlanner(id, name) {
    schedulePanel.setAttribute("data-current-loc-id", id);
    scheduleDjName.textContent = `ADDING SCHEDULE FOR: ${name.toUpperCase()}`;
    schedulePanel.classList.remove("hidden");

    // Pre-fill showing daily or weekly values
    schedType.value = "daily";
    weeklyDayGroup.classList.add("hidden");
    document.getElementById("sched-time").value = "12:00";
    document.getElementById("sched-duration").value = "60";
    schedulePanel.scrollIntoView({ behavior: "smooth" });
  }

  // Add schedule (guardrail validation happens in backend)
  scheduleForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const locId = schedulePanel.getAttribute("data-current-loc-id");
    const type = schedType.value;
    const dayOfWeek =
      type === "weekly"
        ? parseInt(document.getElementById("sched-day").value, 10)
        : null;
    const startHour = document.getElementById("sched-time").value;
    const duration = parseInt(
      document.getElementById("sched-duration").value,
      10,
    );

    const payload = { type, dayOfWeek, startHour, duration };

    try {
      const res = await fetch(`/api/locutors/${locId}/schedules`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      const json = await res.json();
      if (json.ok) {
        showAlert("Schedule slot added successfully.");
        schedulePanel.classList.add("hidden");
        loadLocutors();
      } else {
        // GUARDRAIL TRIPPED! Show big red warning
        showAlert(`CONFLICT ERROR: ${json.error}`, "error");
      }
    } catch (err) {
      showAlert(err.message, "error");
    }
  });

  // Delete schedule slot
  async function deleteSchedule(locId, schedId) {
    try {
      const res = await fetch(`/api/locutors/${locId}/schedules/${schedId}`, {
        method: "DELETE",
      });
      const json = await res.json();
      if (json.ok) {
        showAlert("Schedule slot removed.");
        loadLocutors();
      } else {
        showAlert(json.error || "Error deleting schedule", "error");
      }
    } catch (err) {
      showAlert(err.message, "error");
    }
  }

  // Init
  loadLocutors();
</script>
