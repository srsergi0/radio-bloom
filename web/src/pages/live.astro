---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Live Broadcast — Radio Bloom">
  <main class="max-w-xl mx-auto px-6 py-16 space-y-8">
    <h1 class="text-4xl font-black uppercase tracking-tight">Live Broadcast</h1>
    <p class="text-zinc-400">Stream your microphone or CABLE Output directly to the radio.</p>

    <div class="space-y-6 border-2 border-white p-6">
      <div class="space-y-2">
        <label class="text-sm font-bold uppercase tracking-wider">Audio Device</label>
        <select id="deviceSelect" class="w-full border-2 border-white bg-black p-3 text-white">
          <option value="">— Select a device —</option>
        </select>
        <button id="refreshDevices" class="text-xs underline text-zinc-500 hover:text-white">Refresh list</button>
      </div>

      <div class="flex gap-4">
        <button id="startBtn" class="flex-1 border-2 border-white px-6 py-3 font-bold uppercase tracking-wider hover:bg-white hover:text-black disabled:opacity-30 disabled:cursor-not-allowed" disabled>
          Start Streaming
        </button>
        <button id="stopBtn" class="flex-1 border-2 border-red-500 text-red-500 px-6 py-3 font-bold uppercase tracking-wider hover:bg-red-500 hover:text-black disabled:opacity-30 disabled:cursor-not-allowed" disabled>
          Stop
        </button>
      </div>
    </div>

    <div id="status" class="border-2 border-zinc-800 p-4 font-mono text-sm space-y-1">
      <div>Status: <span id="statusText" class="text-zinc-500">Idle</span></div>
      <div>Streaming: <span id="streamTime">—</span></div>
      <div>Audio format: <span id="audioFormat">—</span></div>
    </div>

    <div id="errorLog" class="text-red-400 text-sm font-mono hidden"></div>
  </main>
</Layout>

<script>
const API_BASE = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1"
    ? "http://localhost:9876"
    : "";

  const deviceSelect = document.getElementById("deviceSelect");
  const refreshBtn = document.getElementById("refreshDevices");
  const startBtn = document.getElementById("startBtn");
  const stopBtn = document.getElementById("stopBtn");
  const statusText = document.getElementById("statusText");
  const streamTime = document.getElementById("streamTime");
  const audioFormat = document.getElementById("audioFormat");

  let mediaRecorder = null;
  let audioStream = null;
  let startTime = null;
  let timerInterval = null;
  let isStreaming = false;

  async function loadDevices() {
    try {
      let permStream = null;
      try {
        permStream = await navigator.mediaDevices.getUserMedia({
          audio: { echoCancellation: false, noiseSuppression: false, autoGainControl: false },
        });
      } catch {}

      const devices = await navigator.mediaDevices.enumerateDevices();
      const audioInputs = devices.filter((d) => d.kind === "audioinput");
      deviceSelect.innerHTML = '<option value="">— Select a device —</option>';
      for (const d of audioInputs) {
        const opt = document.createElement("option");
        opt.value = d.deviceId;
        opt.textContent = d.label || `Microphone ${deviceSelect.options.length}`;
        deviceSelect.appendChild(opt);
      }

      if (permStream) for (const t of permStream.getTracks()) t.stop();

      if (audioInputs.length === 0) {
        statusText.textContent = "No audio input devices found";
        statusText.className = "text-red-400";
      }
    } catch (err) {
      statusText.textContent = "Error loading devices: " + err.message;
      statusText.className = "text-red-400";
    }
  }

  deviceSelect.addEventListener("change", () => {
    startBtn.disabled = !deviceSelect.value;
  });

  refreshBtn.addEventListener("click", loadDevices);
  startBtn.addEventListener("click", startStreaming);
  stopBtn.addEventListener("click", stopStreaming);

  async function startStreaming() {
    if (!deviceSelect.value) return;
    setStatus("Requesting microphone...", "text-yellow-400");

    try {
      const mediaStream = await navigator.mediaDevices.getUserMedia({
        audio: {
          deviceId: { exact: deviceSelect.value },
          echoCancellation: false,
          noiseSuppression: false,
          autoGainControl: false,
        },
      });

      audioFormat.textContent = "PCM f32le 48kHz";
      setStatus("Streaming live", "text-green-400");
      isStreaming = true;
      startBtn.disabled = true;
      stopBtn.disabled = false;
      deviceSelect.disabled = true;
      startTimer();

      // Use AudioContext to capture raw PCM
      const audioCtx = new AudioContext({ sampleRate: 48000 });
      const source = audioCtx.createMediaStreamSource(mediaStream);
      const processor = audioCtx.createScriptProcessor(4096, 2, 2);

      processor.onaudioprocess = (event) => {
        const input = event.inputBuffer;
        const channelData: Float32Array[] = [];
        for (let ch = 0; ch < input.numberOfChannels; ch++) {
          channelData.push(input.getChannelData(ch));
        }

        // Interleave channels and convert to Float32 buffer
        const frameCount = input.length;
        const numChannels = input.numberOfChannels;
        const interleaved = new Float32Array(frameCount * numChannels);
        for (let i = 0; i < frameCount; i++) {
          for (let ch = 0; ch < numChannels; ch++) {
            interleaved[i * numChannels + ch] = channelData[ch][i];
          }
        }

        // Send raw PCM chunk
        fetch(`${API_BASE}/api/live/chunk`, {
          method: "POST",
          headers: { "Content-Type": "audio/x-raw" },
          body: interleaved.buffer,
        }).catch(() => {});
      };

      processor.connect(audioCtx.destination);
      audioStream = mediaStream;

      // Store for cleanup
      (window as any).__audioCtx = audioCtx;
      (window as any).__processor = processor;
    } catch (err) {
      setStatus("Error: " + err.message, "text-red-400");
    }
  }

  function stopStreaming() {
    const audioCtx = (window as any).__audioCtx;
    const processor = (window as any).__processor;
    if (processor) processor.disconnect();
    if (audioCtx) audioCtx.close();
    cleanup();
    fetch(`${API_BASE}/api/live/stop`, { method: "POST" }).catch(() => {});
    setStatus("Stopped", "text-zinc-500");
  }

  function cleanup() {
    isStreaming = false;
    if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
    if (audioStream) {
      for (const track of audioStream.getTracks()) track.stop();
      audioStream = null;
    }
    startBtn.disabled = !deviceSelect.value;
    stopBtn.disabled = true;
    deviceSelect.disabled = false;
    streamTime.textContent = "—";
    startTime = null;
  }

  function setStatus(msg, className) {
    statusText.textContent = msg;
    statusText.className = className || "text-zinc-400";
  }

  function startTimer() {
    startTime = Date.now();
    timerInterval = setInterval(() => {
      const elapsed = Math.floor((Date.now() - startTime) / 1000);
      const m = String(Math.floor(elapsed / 60)).padStart(2, "0");
      const s = String(elapsed % 60).padStart(2, "0");
      streamTime.textContent = `${m}:${s}`;
    }, 1000);
  }

  window.addEventListener("beforeunload", () => {
    const audioCtx = (window as any).__audioCtx;
    if (audioCtx) audioCtx.close();
    if (audioStream) for (const t of audioStream.getTracks()) t.stop();
  });

  loadDevices();
  navigator.mediaDevices.addEventListener("devicechange", loadDevices);
</script>
